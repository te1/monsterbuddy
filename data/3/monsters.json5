[
  // https://monsterhunterwiki.org/wiki/Aenshin_(MHST3)
  {
    hidden: true,
    name: 'Aenshin',
    genus: 'Elder Dragon',
    flavor: {
      DEFAULT: 'This enormous Elder Dragon preserved the Sacrosanctum\'s ecosystem 200 years ago, earning it the title of "Sentinel," but it vanished after the Sacrosanctum was destroyed during the Rift War.',
      'Crystallizing Capacity': 'After devouring battle-bound monsters during the war 200 years ago, this monster gave rise to the Crystal Encroachment. Traces of its existence have begun reappearing over the last decade.',
      'Catalyst of Devastation': "While this monster preyed on the Sacrosanctum's enemies and helped it prosper, it also sought to eliminate the battle-bound monsters used in the Rift War, leading to the Sacrosanctum's destruction.",
    },
    stats: {
      ailmentResistance: {
        poison: -2,
        burn: -2,
        paralysis: +2,
        sleep: +2,
        blastblight: -1,
        bleeding: -2,
        darkness: -2,
      },
      elementalResistance: {
        none: 2,
        fire: -2,
        water: -1,
        thunder: -1,
        ice: -1,
        dragon: -2,
      },
      base: {
        attack: 1,
        defense: 1,
        hp: 1,
        rawCrit: 0,
        rawSpeed: 6,
      },
    },
  },

  // https://monsterhunterwiki.org/wiki/Ajarakan_(MHST3)
  {
    name: 'Ajarakan',
    genus: 'Fanged Beast',
    related: [{ type: 'feral', monster: 'Feral Ajarakan' }],
    rank: 5,
    flavor: {
      DEFAULT: 'This Fanged Beast affixes molten metals to its carapace, and the friction resulting from those minerals rubbing together allows it to accumulate heat and cause explosions.',
      'Like a Blaze': 'Its high body heat is thought to result from the friction that arises as metals adhered to its body rub together. The shoulder protrusions get so hot that they melt projectiles on contact.',
      'No Limits': 'Typically a quadruped, this highly mobile monster is also capable of bipedal movement, during which it will use its powerful arms to clamber onto high objects.',
    },
    element: 'fire',
    stats: {
      base: {
        hp: 7,
        attack: 7,
        defense: 3,
        stamina: 10,
        startingStamina: 70,
        recovery: 4,
        rawRecovery: 4,
        wyvernfell: 40,
        speed: 5,
        rawSpeed: 10,
        crit: 6,
        rawCrit: 10,
      },
      elementalResistance: {
        none: 0,
        fire: 2,
        water: -2,
        thunder: 1,
