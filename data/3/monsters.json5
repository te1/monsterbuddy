      { type: 'deviant', monster: 'Dreadking Rathalos' },
      // { type: 'story', monster: 'Skyscale Ratha' },
    ],
    rank: 5,
    flavor: {
      DEFAULT: 'Simply mentioning Flying Wyverns brings this fire-breathing monster to mind. Aptly known as the "King of the Skies," it spends little time on land, instead using its powerful wings to hunt from above.',
      "Sky King's Testament": 'Most Flying Wyverns struggle with long-duration flight, but thanks to its powerful wings, the Rathalos can fly continuously for days and still move with enough precision to capture birds in flight.',
      'Poison Secretion Location': "While Rathian have poison-secreting organs in their tails, males of the species possess poisonous claws. This is attributed to the Rathalos' preference for airborne attacks.",
    },
    element: 'fire',
