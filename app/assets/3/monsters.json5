  {
    name: 'Anjanath',
    genus: 'Brute Wyvern',
    rank: 4,
    flavor: {
      DEFAULT: 'A belligerent Brute Wyvern that tries to sink its fangs into anything that moves. It is recognizable by the large membranes on its hips and the downy fur that runs along its back.',
      'Condensing Heat': 'This monster condenses heat when enraged, causing a combustible substance to collect in a throat gland. The resulting mucus can then be expelled its nose to react explosively with the air.',
    },
    element: 'fire',
    stats: {
      base: {
        hp: 6,
        attack: 7,
        speed: 5,
        defense: 4,
        crit: 1,
        recovery: 4,
        stamina: 10,
      },
      elementalResistance: {
        none: 0,
        fire: +2,
        water: -2,
        thunder: 0,
        ice: -1,
        dragon: +1,
      },
